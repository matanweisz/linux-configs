# ---- Kubernetes ----
alias k='kubectl'
alias kg='kubectl get'
alias ka='kubectl apply -f'
alias kd='kubectl describe'
alias kl='kubectl logs'
alias ke='kubectl exec -it'
alias kns='kubens'
alias kctx='kubectx'
alias k9='k9s'

# Interactive kubectl context switcher
kco() {
    if ! command -v kubectl &>/dev/null; then
        echo "kubectl is not installed." >&2
        return 1
    fi
    local contexts=("${(@f)$(kubectl config get-contexts --no-headers | awk '{print $1}')}")
    if [[ ${#contexts[@]} -eq 0 ]]; then
        echo "No contexts found."
        return 1
    fi
    local current=$(kubectl config current-context 2>/dev/null)
    echo "Kubernetes contexts:"
    for i in {1..${#contexts[@]}}; do
        local mark=""
        [[ "$current" == "${contexts[$i]}" ]] && mark="*"
        printf "  [%d] %s %s\n" "$i" "$mark" "${contexts[$i]}"
    done
    echo -n "Switch to: "
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#contexts[@]} )); then
        kubectl config use-context "${contexts[$choice]}"
    else
        echo "Invalid selection." >&2
    fi
}

# Interactive AWS profile switcher
awsuser() {
    if ! command -v aws &>/dev/null; then
        echo "aws CLI is not installed." >&2
        return 1
    fi
    local profiles=("${(@f)$(aws configure list-profiles)}")
    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo "No profiles found."
        return 1
    fi
    echo "AWS profiles:"
    for i in {1..${#profiles[@]}}; do
        local mark=""
        [[ "${AWS_PROFILE:-default}" == "${profiles[$i]}" ]] && mark="*"
        printf "  [%d] %s %s\n" "$i" "$mark" "${profiles[$i]}"
    done
    echo -n "Switch to: "
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#profiles[@]} )); then
        export AWS_PROFILE="${profiles[$choice]}"
        echo "Switched to: $AWS_PROFILE"
        aws sts get-caller-identity --output text 2>/dev/null | awk '{print "Account:", $1, "| User:", $2}' || true
    else
        echo "Invalid selection." >&2
    fi
}

# EC2 instance listing
ec2ls() {
    printf "%-20s %-10s %-20s %-15s %-15s %-10s\n" "Name" "State" "ID" "PublicIP" "PrivateIP" "Type"
    printf '%0.s-' {1..95}; echo
    aws ec2 describe-instances \
        --query "Reservations[*].Instances[*].{Name:Tags[?Key==\`Name\`]|[0].Value,State:State.Name,ID:InstanceId,PublicIP:PublicIpAddress,PrivateIP:PrivateIpAddress,Type:InstanceType}" \
        --output json | jq -r '.[][] | "\(.Name // "N/A")\t\(.State)\t\(.ID)\t\(.PublicIP // "N/A")\t\(.PrivateIP // "N/A")\t\(.Type)"' |
        while IFS=$'\t' read -r name state id pub priv type; do
            printf "%-20s %-10s %-20s %-15s %-15s %-10s\n" "$name" "$state" "$id" "$pub" "$priv" "$type"
        done
}

# SSH to EC2 instance
ec2ssh() {
    [[ $# -lt 1 ]] && { echo "Usage: ec2ssh <instance-id>"; return 1; }
    local id=$1
    local key=$(aws ec2 describe-instances --instance-ids "$id" --query "Reservations[0].Instances[0].KeyName" --output text)
    local ip=$(aws ec2 describe-instances --instance-ids "$id" --query "Reservations[0].Instances[0].PublicIpAddress" --output text)
    local ami=$(aws ec2 describe-instances --instance-ids "$id" --query "Reservations[0].Instances[0].ImageId" --output text)
    local os=$(aws ec2 describe-images --image-ids "$ami" --query "Images[0].Name" --output text)
    local user="ec2-user"
    [[ "$os" == *"ubuntu"* ]] && user="ubuntu"
    [[ "$ip" == "None" || -z "$ip" ]] && { echo "No public IP found."; return 1; }
    echo "Connecting to $ip as $user..."
    ssh -i ~/ssh_keys/"${key}.pem" -o StrictHostKeyChecking=no "$user@$ip"
}

